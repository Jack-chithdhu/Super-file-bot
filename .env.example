# ════════════════════════════════════════════
#   File Sharing Bot — Environment Variables
# ════════════════════════════════════════════

# ── REQUIRED ────────────────────────────────
TG_BOT_TOKEN=          # From @BotFather
APP_ID=                # From my.telegram.org
API_HASH=              # From my.telegram.org
OWNER_ID=              # Your Telegram user ID
CHANNEL_ID=            # DB Channel ID e.g. -100xxxxxxxxxx
DATABASE_URL=          # MongoDB Atlas URL

# ── DATABASE ────────────────────────────────
DATABASE_NAME=filesharexbot

# ── FORCE SUBSCRIBE ─────────────────────────
FORCE_SUB_CHANNEL=0           # 0 = disabled
JOIN_REQUEST_ENABLED=False    # True = use join requests

# ── REQUESTS CHANNEL ────────────────────────
REQUEST_CHANNEL_ID=0          # Channel for movie/anime requests (0 = disabled)

# ── ADMINS ──────────────────────────────────
ADMINS=                       # Space-separated user IDs e.g. "123456 789012"

# ── CONTENT PROTECTION ──────────────────────
PROTECT_CONTENT=False

# ── AUTO DELETE ─────────────────────────────
AUTO_DELETE_TIME=0            # Seconds (0 = disabled)
AUTO_DELETE_MSG=⏳ This file will be deleted in {time} seconds. Please save it!
AUTO_DEL_SUCCESS_MSG=✅ File deleted successfully. Thank you!

# ── MESSAGES ────────────────────────────────
START_MESSAGE=                # Leave blank for default
START_PIC=                    # Image URL for start message
FORCE_SUB_MESSAGE=            # Leave blank for default
CUSTOM_CAPTION=               # Leave blank for default

# ── PREMIUM ─────────────────────────────────
PREMIUM_DURATION_DAYS=30
FREE_DAILY_LIMIT=20

# ── PERFORMANCE ─────────────────────────────
TG_BOT_WORKERS=8
PORT=8080
